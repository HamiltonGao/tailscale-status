# Tailscale Configuration
# The container needs access to Tailscale socket or API
TAILSCALE_API_KEY=your_api_key_here
TAILSCALE_TAILNET=your_tailnet_name.tailnet-xxx.ts.net

# Polling Configuration
NODE_SYNC_INTERVAL_SEC=300
PING_POLLING_INTERVAL_SEC=60
PING_TIMEOUT_MS=5000

# Data Retention
DATA_RETENTION_DAYS=30

# Debug
DEBUG_MODE=false
SHOW_RAW_OUTPUT=true

# Server
PORT=3000
NODE_ENV=production
