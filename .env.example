# Tailscale Configuration
# The container needs access to Tailscale socket or API
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAILSCALE_TAILNET=your_tailnet_name.ts.net

# Polling Configuration
NODE_SYNC_INTERVAL_SEC=10
PING_POLLING_INTERVAL_SEC=30
PING_TIMEOUT_MS=5000

# Data Retention
DATA_RETENTION_DAYS=30

# Debug
DEBUG_MODE=false

# Server
PORT=3000
NODE_ENV=production
